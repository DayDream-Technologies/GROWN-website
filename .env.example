## Public Vite variables (safe to expose in browser bundle)
VITE_BFF_ORIGIN=http://localhost:8787
VITE_SQUARE_APPLICATION_ID=sq0idp-your-public-app-id
VITE_CONTACT_EMAIL=hello@example.com

## Server variables (never prefix with VITE_)
## Keep secrets only in server runtime env.
SQUARE_ACCESS_TOKEN=EAAA-your-square-access-token
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=YOUR_LOCATION_ID
SQUARE_APPLICATION_ID=sq0idp-your-public-app-id

## Node BFF runtime
PORT=8787
